# SportsUp secrets — copy to `.env` and fill in. `.env` is git-ignored; never commit it.
# All keys are optional in Phase 1 (skeleton boots without them); they get wired up in later phases.

# --- Sports data providers (Phase 2) ---
# football-data.org free API token: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# API-Football (api-sports.io) key, used for pre-match odds: https://www.api-football.com/
API_FOOTBALL_KEY=

# --- Delivery: Telegram (free) ---
# Create a bot via @BotFather -> /newbot, paste the token. Then message your bot once and get
# your numeric chat id (e.g. from @userinfobot). Set delivery.provider: telegram in config.yaml.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Master safety switch: when true, messages are printed to console instead of sent. Default true.
SPORTSUP_DRY_RUN=true

# --- Admin dashboard (read-only; localhost + SSH tunnel) ---
# REQUIRED to run `sportsup dashboard` — it refuses to start without a password.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
